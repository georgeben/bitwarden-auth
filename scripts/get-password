#!/usr/bin/env bash
set -euo pipefail

# Usage:
#   get-password "Item Name"
#
# Purpose:
#   Return only the password from a Vaultwarden/Bitwarden login item.
#
# Notes:
# - Keeps the output narrow: password only, not the full item JSON.
# - Uses the same unlock/lock flow as the other helpers.

ITEM_NAME="${1:?usage: get-password \"Item Name\"}"

# Make the Node-based Bitwarden CLI trust your local HTTPS setup.
export NODE_USE_SYSTEM_CA=1

# Read the Vaultwarden master password from macOS Keychain.
export BW_PASSWORD="$(security find-generic-password -a codex -s bw-master -w)"

# Unlock the vault and capture the session token for subsequent bw commands.
export BW_SESSION="$(bw unlock --passwordenv BW_PASSWORD --raw)"

# Re-lock on exit so the unlocked session is short-lived.
trap 'bw lock >/dev/null 2>&1 || true' EXIT

# Sync to ensure fresh vault data.
bw sync >/dev/null

# Print only the password for the specified item.
bw get password "$ITEM_NAME"